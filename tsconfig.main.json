{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.main.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node", "electron"],
    "skipLibCheck": true,
    "module": "nodenext",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/data/*": ["src/shared/data/*"]
    },
    "outDir": "dist/main",
    "rootDir": "src/main",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/main/**/*"],
  "exclude": ["src/main/**/*.test.ts", "src/shared/components/ui/**/*", "src/shared/components/PlaceholderPage.tsx", "src/features/**/*"]
}
